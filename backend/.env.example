# ===== App =====
DEBUG=True

# ===== PostgreSQL Database =====
# Local:
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/product_analyser
# Render/Railway (replace with your connection string):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ===== Security =====
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ===== Google Gemini AI =====
GEMINI_API_KEY=your-gemini-api-key-here

# ===== ML =====
USE_TRANSFORMER_SENTIMENT=False
